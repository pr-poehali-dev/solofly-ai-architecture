{
  "tests": [
    {
      "name": "GET all missions",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": { "total": 4 },
      "bodyMatcher": "partial"
    },
    {
      "name": "GET active missions",
      "method": "GET",
      "path": "/?status=active",
      "expectedStatus": 200,
      "expectedBody": { "stats": {} },
      "bodyMatcher": "partial"
    },
    {
      "name": "GET mission by id",
      "method": "GET",
      "path": "/?id=1",
      "expectedStatus": 200,
      "expectedBody": { "mission": { "id": 1 } },
      "bodyMatcher": "partial"
    }
  ]
}