      "name": "GET scan session SCN-001",
      "method": "GET",
      "path": "/?id=1",
      "expectedStatus": 200,
      "expectedBody": {"session": {"id": 1, "code": "SCN-001"}},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET scan sessions list",
      "method": "GET",
      "path": "/",
